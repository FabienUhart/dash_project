# Modèle de configuration d'environnement — COPIER en .env (gitignoré) et remplir.
# Ne JAMAIS committer .env (déjà dans .gitignore). Ne pas mettre de vrais secrets ici.
#
# SMTP pour l'envoi des liens-hub par e-mail aux invités ([HUB-EMAIL-INVITE]).
# Avec Gmail : créer un « mot de passe d'application » (myaccount.google.com/apppasswords,
# validation en 2 étapes requise) — clé de 16 caractères à coller dans SMTP_PASS du .env.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ton.adresse@gmail.com
SMTP_PASS=
SMTP_FROM=Dashboard <ton.adresse@gmail.com>
